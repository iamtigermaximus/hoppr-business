  bar  Bar  @relation(fields: [barId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])

  @@index([barId, createdAt])
  @@map("outreach_logs")
}

// ============================================
// AUDIT & IMPORT
